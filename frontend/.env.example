# === API ===
# URL бекенда, должен заканчиваться на /api/v1
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Публичный origin S3/CloudFront для next/image в галереях контент-блоков (без завершающего /)
# NEXT_PUBLIC_S3_PUBLIC_ORIGIN=https://your-bucket.s3.amazonaws.com

# === Сайт ===
# Публичный URL самого фронтенда
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Название сайта (SEO, Open Graph)
NEXT_PUBLIC_SITE_NAME=Профессиональное общество Трихологов
